# StudentOS online layer (OPTIONAL).
# Copy to .env.local and fill in to enable accounts + cross-device sync.
# Without these, StudentOS runs fully offline (IndexedDB only) — no account.

# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Rate-limit dei proxy /api/{assistente,import-pdf,alerts,…} (OPZIONALE).
# Il limite è a due livelli: un cookie firmato HMAC (persistente cross-istanza,
# risolve il limite aggirabile colpendo istanze serverless diverse) + un backstop
# per-IP in-memory. Questa è la chiave di firma del cookie: server-only, mai
# inviata al client (l'HMAC è a senso unico). Se assente si usa GROQ_API_KEY come
# fallback; se manca anche quella, resta solo il backstop in-memory.
# Genera un valore casuale, es:  openssl rand -base64 32
RATE_LIMIT_SECRET=

# Apply the schema in supabase/migrations/0001_init.sql via the Supabase SQL editor.
#
# Auth: email + password (the single sign-in for every ateneo). In the Supabase
# dashboard → Authentication:
#   - Providers → Email: enabled, keep "Confirm email" ON.
#   - URL Configuration → add these redirect URLs:
#       <your-origin>/auth/callback
#       <your-origin>/auth/reset
#   - Rate limits are enforced by Supabase (Auth → Rate Limits); no app config.
