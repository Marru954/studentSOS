# StudentOS online layer (OPTIONAL).
# Copy to .env.local and fill in to enable accounts + cross-device sync.
# Without these, StudentOS runs fully offline (IndexedDB only) — no account.

# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Apply the schema in supabase/migrations/0001_init.sql via the Supabase SQL editor.
#
# Auth: email + password (the single sign-in for every ateneo). In the Supabase
# dashboard → Authentication:
#   - Providers → Email: enabled, keep "Confirm email" ON.
#   - URL Configuration → add these redirect URLs:
#       <your-origin>/auth/callback
#       <your-origin>/auth/reset
#   - Rate limits are enforced by Supabase (Auth → Rate Limits); no app config.
