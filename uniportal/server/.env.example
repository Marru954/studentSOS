# ── Ambiente ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# URL pubblico del Service Provider (questo backend) e del client React.
SP_BASE_URL=http://localhost:4000
CLIENT_URL=http://localhost:5173

# ── Database (PostgreSQL) ───────────────────────────────────────────────────
# Sessioni utente + dati sincronizzati. Vedi docker-compose.yml.
DATABASE_URL=postgresql://uniportal:uniportal@localhost:5432/uniportal?schema=public

# Segreto per firmare i cookie di sessione (cambialo!).
SESSION_SECRET=cambia-questo-segreto-in-produzione

# ── Service Provider SAML ───────────────────────────────────────────────────
# entityID del SP (deve coincidere con quello nel metadata registrato presso l'IdP).
SP_ENTITY_ID=http://localhost:4000/saml/metadata
# Assertion Consumer Service (dove l'IdP rimanda la SAML Response, binding POST).
SP_ACS_URL=http://localhost:4000/saml/acs
# Single Logout Service del SP.
SP_SLO_URL=http://localhost:4000/saml/logout/callback
# Chiavi del SP (genera con `npm run certs`).
SP_PRIVATE_KEY_PATH=./certs/sp-private-key.pem
SP_CERT_PATH=./certs/sp-public-cert.pem

# ── Identity Provider (Tor Vergata) ─────────────────────────────────────────
IDP_ENTITY_ID=https://idp.uniroma2.it/idp/shibboleth
IDP_ENTRY_POINT=https://idp.uniroma2.it/idp/profile/SAML2/Redirect/SSO
IDP_LOGOUT_URL=https://idp.uniroma2.it/idp/profile/SAML2/Redirect/SLO
# Certificato di firma dell'IdP (scaricalo dal suo metadata): certs/idp-cert.pem
IDP_CERT_PATH=./certs/idp-cert.pem
